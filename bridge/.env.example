# Copy to .env and edit. These override config.json; both are optional.

# Connection
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=8765
# Shared secret the glasses must send (?token=...). Leave blank to auto-generate.
BRIDGE_TOKEN=

# Driving mode: tmux (live-mirror a pane, shared with PC) or headless
BRIDGE_MODE=tmux
# Project dir for headless mode (tmux mode picks panes at runtime)
BRIDGE_CWD=.
# default | acceptEdits | plan | bypassPermissions
BRIDGE_PERMISSION_MODE=acceptEdits
# Optional model override (blank = account default)
BRIDGE_MODEL=
# false = confirm each transcribed message before sending (recommended)
BRIDGE_AUTO_SEND=false

# Speech-to-text (local whisper)
WHISPER_BIN=whisper
WHISPER_MODEL=turbo
WHISPER_LANGUAGE=ja
WHISPER_INITIAL_PROMPT=

# tmux mirror tuning
TMUX_POLL_MS=700
TMUX_COLS=50
TMUX_ROWS=28
TMUX_SCROLLBACK=200
