{
  "name": "even-claude-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Bridge server that lets Even G2 glasses drive Claude Code over the LAN (voice -> STT -> claude headless -> streamed output).",
  "bin": {
    "even-claude-bridge": "src/index.ts"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
